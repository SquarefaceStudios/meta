{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/ecm/component.json",
  "version": "1.0.0",
  "description": "[Component] A representation of a Component, serialized in JSON format",
  "type": "object",

  "properties": {
    "type": {
      "description": "[Component] Kind of component this is supposed to be.",
      "enum": [
        "ActorRef",
        "EntityEventAdapter",
        "MeshRef",
        "MeshRendererRef",
        "SpriteSheetMapper",
        "TextureRef",
        "Transform"
      ]
    },

    "formatVersion": {
      "description": "[Component] Version of this file format",
      "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/common/version.json"
    }
  },

  "allOf": [
    {
      "comment": "Must provide 'type' or 'derivedFrom' when standalone.",
      "anyOf": [
        {
          "required": ["type"]
        },
        {
          "required": ["derivedFrom"]
        }
      ]
    },

    {
      "$comment": "If is an actor ref",
      "if": {
        "properties": {
          "type": {
            "const": "ActorRef"
          },
          "derivedFrom": {
            "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/actorRefBlueprintId"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/actorRef"
      }
    },

    {
      "$comment": "If is an entity event adapter",
      "if": {
        "properties": {
          "type": {
            "const": "EntityEventAdapter"
          },
          "derivedFrom": {
            "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/entityEventAdapterBlueprintId"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/entityEventAdapter"
      }
    },

    {
      "$comment": "If is a mesh ref",
      "if": {
        "properties": {
          "type": {
            "const": "MeshRef"
          },
          "derivedFrom": {
            "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/meshRefBlueprintId"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/meshRef"
      }
    },

    {
      "$comment": "If is a mesh renderer ref",
      "if": {
        "properties": {
          "type": {
            "const": "MeshRendererRef"
          },
          "derivedFrom": {
            "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/meshRendererRefBlueprintId"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/meshRendererRef"
      }
    },

    {
      "$comment": "If is a sprite sheet mapper",
      "if": {
        "properties": {
          "type": {
            "const": "SpriteSheetMapper"
          },
          "derivedFrom": {
            "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/spriteSheetMapperBlueprintId"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/spriteSheetMapper"
      }
    },

    {
      "$comment": "If is a texture ref",
      "if": {
        "properties": {
          "type": {
            "const": "TextureRef"
          },
          "derivedFrom": {
            "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/textureRefBlueprintId"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/textureRef"
      }
    },

    {
      "$comment": "If is a transform",
      "if": {
        "properties": {
          "type": {
            "const": "Transform"
          },
          "derivedFrom": {
            "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/transformBlueprintId"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/transform"
      }
    }
  ],

  "$defs": {
    "actorRef": {
      "required": [
        "lib",
        "name"
      ],
      "properties": {
        "lib": {
          "type": "string",
          "description": "[ActorRef] Relative path from project root of the compiled shared library containing actor code."
        },
        "name": {
          "type": "string",
          "description": "[ActorRef] Name of actor class, used in querying actor functions from library."
        },
        "derivedFrom": {
          "description": "[Component] Blueprint id of the actor ref blueprint to apply to this component.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/actorRefBlueprintId"
        }
      }
    },

    "entityEventAdapter": {
      "required": [
        "keyEventAdapter"
      ],
      "properties": {
        "keyEventAdapter": {
          "type": "object",
          "description": "[EntityEventAdapter] Placeholder value. Incomplete, but must be defined for now."
        },
        "derivedFrom": {
          "description": "[Component] Blueprint id of the entity event adapter blueprint to apply to this component.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/entityEventAdapterBlueprintId"
        }
      }
    },

    "meshRef": {
      "properties": {
        "derivedFrom": {
          "description": "[Component] Blueprint id of the mesh ref blueprint to apply to this component.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/meshRefBlueprintId"
        }
      },
      "anyOf": [
        {
          "required": [
            "standardMeshType"
          ],
          "properties": {
            "standardMeshType": {
              "type": "string",
              "description": "[MeshRef] A standard mesh type identifier."
            }
          }
        },
        {
          "required": [
            "path"
          ],
          "properties": {
            "path": {
              "type": "string",
              "description": "[MeshRef] Relative path from project root of the file containing the mesh data."
            }
          }
        }
      ]
    },

    "meshRendererRef": {
      "required": [
        "shader"
      ],
      "properties": {
        "shader": {
          "type": "string",
          "description": "[MeshRendererRef] The identifier of the shader program used to render the mesh of the entity this is attached to."
        },
        "derivedFrom": {
          "description": "[Component] Blueprint id of the mesh renderer ref blueprint to apply to this component.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/meshRendererRefBlueprintId"
        }
      }
    },

    "spriteSheetMapper": {
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "object",
          "description": "[SpriteSheetMapper] Where to obtain the sprite sheet to map.",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "description": "[SpriteSheetMapper.source] Kind of source of sprite sheet. self = from current object's TextureRef.",
              "enum": [
                "self"
              ]
            }
          }
        },
        "sprites": {
          "type": "array",
          "description": "[SpriteSheetMapper] Regions to extract from the sprite sheet.",
          "items": {
            "type": "object",
            "description": "[SpriteSheetMapper.sprites] A rectangular region to extract a sprite from the sprite sheet.",
            "properties": {
              "position": {
                "type": "object",
                "description": "[SpriteSheetMapper.sprites[k]] The top-left corner of the rectangular region of the sprite.",
                "properties": {
                  "x": {
                    "type": "integer",
                    "description": "[SpriteSheetMapper.sprites[k].position] The x coordinate of the top-left rectangular region."
                  },
                  "y": {
                    "type": "integer",
                    "description": "[SpriteSheetMapper.sprites[k].position] The y coordinate of the top-left rectangular region."
                  }
                }
              },
              "size": {
                "type": "object",
                "description": "[SpriteSheetMapper.sprites[k]] The size of the rectangular region of the sprite.",
                "properties": {
                  "width": {
                    "type": "integer",
                    "description": "[SpriteSheetMapper.sprites[k].size] The width of the rectangular region."
                  },
                  "height": {
                    "type": "integer",
                    "description": "[SpriteSheetMapper.sprites[k].size] The height of the rectangular region."
                  }
                }
              }
            }
          }
        },
        "derivedFrom": {
          "description": "[Component] Blueprint id of the sprite sheet mapper blueprint to apply to this component.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/spriteSheetMapperBlueprintId"
        }
      }
    },

    "textureRef": {
      "required": [
        "image"
      ],
      "properties": {
        "image": {
          "type": "object",
          "description": "[TextureRef] The image identification data of the texture.",
          "anyOf": [
            {
              "required": [
                "id"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "[TextureRef.image] The standard identifier of an image."
                }
              }
            },
            {
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "description": "[TextureRef.image] The path, relative to the project root, of the image file to use."
                }
              }
            }
          ],
          "properties": {
            "metaPath": {
              "type": "string",
              "description": "[TextureRef.image] The path, relative to the project root, of the image meta-information file."
            }
          }
        },
        "derivedFrom": {
          "description": "[Component] Blueprint id of the texture ref blueprint to apply to this component.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/textureRefBlueprintId"
        }
      }
    },

    "transform": {
      "properties": {
        "position": {
          "description": "[Transform] The position in 3D space of the entity.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/common/vec3.json"
        },
        "rotation": {
          "description": "[Transform] The rotation in 3D space of the entity.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/common/vec3.json"
        },
        "scale": {
          "description": "[Transform] The scale in 3D space of the entity.",
          "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/common/vec3.json"
        }
      },
      "derivedFrom": {
        "description": "[Component] Blueprint id of the transform blueprint to apply to this component.",
        "$ref": "https://raw.githubusercontent.com/SquarefaceStudios/meta/refs/heads/vl/squiby-schemas/squiby/schemas/blueprint/blueprint_id.json#/$defs/transformBlueprintId"
      }
    }
  }
}
